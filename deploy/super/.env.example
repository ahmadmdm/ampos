# ─── Required ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@postgres_host:5432/ampos_db

# Super-admin login credentials
SUPER_ADMIN_EMAIL=super@ampos.local
# Generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('YourPassword',12))"
SUPER_ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT signing secret for super-admin tokens (use a long random string)
SUPER_JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars

# ─── Optional ─────────────────────────────────────────────────────────────────
PORT=3200
NODE_ENV=production
